    <definition value="An antisense oligonucleotide (ASO) that binds to a complementary mRNA sequence to inhibit gene expression."/>
  </concept>
  <concept>
    <code value="sirna"/>
    <display value="Small interfering RNA (siRNA)"/>
    <definition value="A short double-stranded RNA that triggers degradation of a target mRNA through the RNA interference pathway."/>
  </concept>
  <concept>
    <code value="mirna"/>
    <display value="MicroRNA (miRNA)"/>
    <definition value="A short non-coding RNA that regulates gene expression by base-pairing with target mRNAs."/>
  </concept>
  <concept>
    <code value="aptamer"/>
    <display value="Aptamer"/>
    <definition value="A short single-stranded oligonucleotide that binds a specific target through its three-dimensional structure."/>
  </concept>
  <concept>
    <code value="decoy"/>
    <display value="Decoy oligonucleotide"/>
    <definition value="An oligonucleotide that mimics a regulatory binding site to sequester a transcription factor or other binding protein."/>
  </concept>
  <concept>
    <code value="ribozyme"/>
    <display value="Ribozyme / DNAzyme"/>
    <definition value="A catalytic oligonucleotide capable of cleaving a target nucleic acid."/>
  </concept>
  <concept>
    <code value="gene-fragment"/>
    <display value="Gene fragment"/>
    <definition value="A fragment of a gene such as a promoter, enhancer, coding region or silencer."/>
