            <coding>
               <system value="http://hl7.org/fhir/substance-name-authority"/>
               <code value="USAN"/>
               <display value="USAN"/>
            </coding>
         </authority>
         <status>
            <coding>
               <system value="http://hl7.org/fhir/publication-status"/>
               <code value="active"/>
               <display value="Active"/>
            </coding>
         </status>
      </official>
   </name>
   <name>
