      </coding>
   </status>
   <classification>
      <coding>
         <system value="http://example.europa.eu/fhir/SubstanceType"/>
         <code value="polymer"/>
         <display value="Polymer"/>
      </coding>
   </classification>
   <domain>
      <coding>
         <system value="http://example.europa.eu/fhir/Domain"/>
         <code value="human"/>
         <display value="Human use"/>
      </coding>
   </domain>
   <description value="Polyethylene Glycol 3350 (PEG 3350, Macrogol 3350) — a synthetic polyether of ethylene oxide with number-average molecular weight approximately 3350 Da. Linear homopolymer used as an osmotic laxative and a pharmaceutical excipient."/>
   <code>
      <code>
         <coding>
            <system value="http://example.europa.eu/fhir/Substance"/>
            <code value="PEG3350P"/>
         </coding>
