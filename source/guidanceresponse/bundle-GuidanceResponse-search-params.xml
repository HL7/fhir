<?xml version="1.0" encoding="UTF-8"?>

<Bundle xmlns="http://hl7.org/fhir">
  <id value="GuidanceResponse-search-params"/>
  <entry>
    <resource>
      <SearchParameter>
        <id value="GuidanceResponse-identifier"/>
        <extension url="http://hl7.org/fhir/StructureDefinition/structuredefinition-standards-status">
          <valueCode value="normative"/>
        </extension>
        <extension url="http://hl7.org/fhir/build/StructureDefinition/path">
          <valueString value="GuidanceResponse.identifier"/>
        </extension>
        <url value="http://hl7.org/fhir/build/SearchParameter/GuidanceResponse-identifier"/>
        <description value="The identifier of the guidance response"/>
        <code value="identifier"/>
        <type value="token"/>
        <expression value="GuidanceResponse.identifier"/>
        <processingMode value="normal"/>
      </SearchParameter>
    </resource>
  </entry>
  <entry>
    <resource>
      <SearchParameter>
        <id value="GuidanceResponse-patient"/>
        <extension url="http://hl7.org/fhir/StructureDefinition/structuredefinition-standards-status">
          <valueCode value="normative"/>
        </extension>
        <extension url="http://hl7.org/fhir/build/StructureDefinition/path">
          <valueString value="GuidanceResponse.subject"/>
        </extension>
        <url value="http://hl7.org/fhir/build/SearchParameter/GuidanceResponse-patient"/>
        <description value="The identity of a patient to search for guidance response results"/>
        <code value="patient"/>
        <type value="reference"/>
        <expression value="GuidanceResponse.subject.where(resolve() is Patient)"/>
        <processingMode value="normal"/>
        <target value="Patient"/>
      </SearchParameter>
    </resource>
  </entry>
  <entry>
    <resource>
      <SearchParameter>
        <id value="GuidanceResponse-request"/>
        <extension url="http://hl7.org/fhir/StructureDefinition/structuredefinition-standards-status">
          <valueCode value="normative"/>
        </extension>
        <extension url="http://hl7.org/fhir/build/StructureDefinition/path">
          <valueString value="GuidanceResponse.requestIdentifier"/>
        </extension>
        <url value="http://hl7.org/fhir/build/SearchParameter/GuidanceResponse-request"/>
        <description value="The identifier of the request associated with the response"/>
        <code value="request"/>
        <type value="token"/>
        <expression value="GuidanceResponse.requestIdentifier"/>
        <processingMode value="normal"/>
      </SearchParameter>
    </resource>
  </entry>
  <entry>
    <resource>
      <SearchParameter>
        <id value="GuidanceResponse-subject"/>
        <extension url="http://hl7.org/fhir/StructureDefinition/structuredefinition-standards-status">
          <valueCode value="normative"/>
        </extension>
        <extension url="http://hl7.org/fhir/build/StructureDefinition/path">
          <valueString value="GuidanceResponse.subject"/>
        </extension>
        <url value="http://hl7.org/fhir/build/SearchParameter/GuidanceResponse-subject"/>
        <description value="The subject that the guidance response is about"/>
        <code value="subject"/>
        <type value="reference"/>
        <expression value="GuidanceResponse.subject"/>
        <processingMode value="normal"/>
      </SearchParameter>
    </resource>
  </entry>
  <entry>
    <resource>
      <SearchParameter>
        <id value="GuidanceResponse-status"/>
        <extension url="http://hl7.org/fhir/build/StructureDefinition/path">
          <valueString value="GuidanceResponse.status"/>
        </extension>
        <extension url="http://hl7.org/fhir/StructureDefinition/structuredefinition-standards-status">
          <valueCode value="normative"/>
        </extension>
        <description value="The status of the guidance response"/>
        <code value="status"/>
        <type value="token"/>
        <expression value="GuidanceResponse.status"/>
        <processingMode value="normal"/>
      </SearchParameter>
    </resource>
  </entry>
  <entry>
    <resource>
      <SearchParameter>
        <id value="GuidanceResponse-module-code"/>
        <extension url="http://hl7.org/fhir/build/StructureDefinition/path">
          <valueString value="GuidanceResponse.module[x]"/>
        </extension>
        <extension url="http://hl7.org/fhir/StructureDefinition/structuredefinition-standards-status">
          <valueCode value="normative"/>
        </extension>
        <description value="The module from which the guidance was provided"/>
        <code value="module-code"/>
        <type value="token"/>
        <expression value="GuidanceResponse.module as CodeableConcept"/>
        <processingMode value="normal"/>
      </SearchParameter>
    </resource>
  </entry>
  <entry>
    <resource>
      <SearchParameter>
        <id value="GuidanceResponse-module-uri"/>
        <extension url="http://hl7.org/fhir/build/StructureDefinition/path">
          <valueString value="GuidanceResponse.module[x]"/>
        </extension>
        <extension url="http://hl7.org/fhir/StructureDefinition/structuredefinition-standards-status">
          <valueCode value="normative"/>
        </extension>
        <description value="The module from which the guidance was provided"/>
        <code value="module-uri"/>
        <type value="uri"/>
        <expression value="GuidanceResponse.module as uri"/>
        <processingMode value="normal"/>
      </SearchParameter>
    </resource>
  </entry>
  <entry>
    <resource>
      <SearchParameter>
        <id value="GuidanceResponse-module-reference"/>
        <extension url="http://hl7.org/fhir/build/StructureDefinition/path">
          <valueString value="GuidanceResponse.module[x]"/>
        </extension>
        <extension url="http://hl7.org/fhir/StructureDefinition/structuredefinition-standards-status">
          <valueCode value="normative"/>
        </extension>
        <description value="The module from which the guidance was provided"/>
        <code value="module-reference"/>
        <type value="reference"/>
        <expression value="GuidanceResponse.module as canonical"/>
        <processingMode value="normal"/>
      </SearchParameter>
    </resource>
  </entry>
  <entry>
    <resource>
      <SearchParameter>
        <id value="GuidanceResponse-date"/>
        <extension url="http://hl7.org/fhir/build/StructureDefinition/path">
          <valueString value="GuidanceResponse.date"/>
        </extension>
        <extension url="http://hl7.org/fhir/StructureDefinition/structuredefinition-standards-status">
          <valueCode value="normative"/>
        </extension>
        <description value="The date on which the guidance was provided"/>
        <code value="module-code"/>
        <type value="date"/>
        <expression value="GuidanceResponse.occurrenceDateTime"/>
        <processingMode value="normal"/>
      </SearchParameter>
    </resource>
  </entry>
  <entry>
    <resource>
      <SearchParameter>
        <id value="GuidanceResponse-topic"/>
        <extension url="http://hl7.org/fhir/StructureDefinition/structuredefinition-standards-status">
          <valueCode value="normative"/>
        </extension>
        <extension url="http://hl7.org/fhir/build/StructureDefinition/path">
          <valueString value="GuidanceResponse.topic"/>
        </extension>
        <url value="http://hl7.org/fhir/build/SearchParameter/GuidanceResponse-topic"/>
        <description value="Topics associated with the guidance"/>
        <code value="topic"/>
        <type value="token"/>
        <expression value="GuidanceResponse.topic"/>
        <processingMode value="normal"/>
      </SearchParameter>
    </resource>
  </entry>
</Bundle>