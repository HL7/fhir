        "text": {
          "status": "additional",
          "div": "<div xmlns='http://www.w3.org/1999/xhtml'>INVALID [imm-2]: isSubpotent=false but subpotentReason is present. This is the core invariant violation — subpotentReason is only meaningful and permitted when the dose is flagged as subpotent.</div>"
        },
        "status": "completed",
